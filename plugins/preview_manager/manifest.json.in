{
  "schema_version": 2,
  "id": "misty.preview-manager",
  "name": "Preview Manager",
  "version": "0.1.0",
  "author": "Misty",
  "description": "Bundled plugin that previews common image formats (PDF support pending MuPDF).",
  "enabled": true,
  "platforms": ["@MISTY_HOST_OS@"],
  "plugin": {
    "abi_version": 3,
    "variants": [
      {
        "os": "@MISTY_HOST_OS@",
        "arch": "@MISTY_HOST_ARCH@",
        "runtime": "@MISTY_HOST_RUNTIME@",
        "library": "@MISTY_PREVIEW_MANAGER_VARIANT_LIBRARY@",
        "sdk_version": "@MISTY_PLUGIN_SDK_VERSION@",
        "build_id": "@MISTY_PLUGIN_BUILD_ID@"
      }
    ]
  }
}
